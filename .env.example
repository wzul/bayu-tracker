# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/condo_db?schema=public

# Cache / Queue
REDIS_URL=redis://localhost:6379

# CHIP Payment Gateway
CHIP_API_KEY=your_chip_api_key
CHIP_BRAND_ID=your_chip_brand_id
CHIP_API_URL=https://gate.chip-in.asia/api/v1/

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@example.com

# Object Storage (RustFS / S3-compatible)
RUSTFS_ENDPOINT=https://s3.example.com
RUSTFS_ACCESS_KEY=your_access_key
RUSTFS_SECRET_KEY=your_secret_key
RUSTFS_BUCKET=condo-maintenance

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Auth
NEXTAUTH_SECRET=your_nextauth_secret

# Cron Jobs
CRON_SECRET=your_cron_secret

# Rate Limiting (seconds)
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_WEBHOOK_MAX=100
RATE_LIMIT_WEBHOOK_WINDOW=60

# LHDN MyInvois e-Invoice (optional)
ENABLE_EINVOICE=false
LHDN_CLIENT_ID=your_lhdn_client_id
LHDN_CLIENT_SECRET=your_lhdn_client_secret
LHDN_API_URL=https://preprod-api.myinvois.hasil.gov.my

# Node
NODE_ENV=development
PORT=3000
TELEGRAM_ADMIN_IDS=2103883
